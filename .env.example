# =============================================================================
# Elise Lead Radar — environment variables (TEMPLATE)
# =============================================================================
# Copy this file to .env.local and fill in the values there.
# .env.local is gitignored; .env.example is committed as a template.
#
# All keys below are FREE to obtain. The app degrades gracefully if any are
# missing (that enricher just skips and the score is computed from what's left).
# =============================================================================

# Required for email generation. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Census API — free, instant. https://api.census.gov/data/key_signup.html
# Used for: tract-level rental vacancy, renter-occupied %, median rent
CENSUS_API_KEY=

# FRED (Federal Reserve Economic Data) — free, instant.
# https://fredaccount.stlouisfed.org/apikey
# Used for: state unemployment, rental CPI, housing market indicators
FRED_API_KEY=

# NewsAPI — free tier 100 req/day. https://newsapi.org/register
# Used for: buying signals (funding, expansion, exec changes, layoffs)
NEWSAPI_KEY=

# OpenWeather — free tier 1000 req/day. https://openweathermap.org/api
# Used for: climate volatility signal (maintenance surge angle)
OPENWEATHER_KEY=

# Shared identity for SEC EDGAR + Census Geocoder (required User-Agent).
# Any "Name email@domain.com" string works; SEC requires this to throttle you.
CONTACT_EMAIL=lead-radar@example.com

# Slack incoming webhook — posts a notification whenever a lead scores "hot".
# Create one at https://api.slack.com/messaging/webhooks and paste the URL.
# Optional. If unset, Slack notifications are silently skipped.
SLACK_WEBHOOK_URL=

# Public URL of this deployment (used to build "Open in Lead Radar" links in
# Slack messages). E.g. https://lead-radar.yourteam.com. Optional.
RADAR_PUBLIC_URL=

# Bearer secret for /api/cron — protects the endpoint from random hits.
# Generate with: openssl rand -hex 32
CRON_SECRET=
